{
  "name": "wipulscan-pro",
  "version": "6.0.0",
  "description": "WIPULSCAN PRO - Spatial WiFi Signal Scanner",
  "main": "electron-simple.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.cobradynamics.wipulscanpro",
    "productName": "WIPULSCAN PRO",
    "directories": {
      "output": "exe-output"
    },
    "files": [
      "**/*",
      "!exe-output/**/*"
    ],
    "win": {
      "target": "portable",
      "icon": "icon-512.png"
    },
    "portable": {
      "artifactName": "WIPULSCAN-PRO-v6.0.exe"
    }
  },
  "devDependencies": {
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1"
  }
}
